generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model School {
  id           Int      @id @default(autoincrement())
  name         String
  motto        String?
  logoPath     String?
  address      String?
  contactName  String?
  contactPhone String?
  academicYear String?
  updatedAt        DateTime @updatedAt
  checkoutDuration Int      @default(14)
}

model Subject {
  id           Int        @id @default(autoincrement())
  name         String     @unique
  category     String?
  openingCount Int        @default(0)
  recovered    Int        @default(0)
  issued       Int        @default(0)
  damaged      Int        @default(0)
  lost         Int        @default(0)
  notes            String?
  averageCondition Float      @default(3.0) // 3=Good, 2=Normal, 1=Damaged
  degradationRate  Float      @default(0.0) // points lost per checkout
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  incidents        Incident[]
  auditLogs        AuditLog[]
  checkouts        Checkout[]
  auditItems       StockAuditItem[]
}

model StockAudit {
  id        Int              @id @default(autoincrement())
  auditDate DateTime         @default(now())
  auditedBy String?
  notes     String?
  status    String           @default("IN_PROGRESS")
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  items     StockAuditItem[]
}

model StockAuditItem {
  id            Int        @id @default(autoincrement())
  auditId       Int
  audit         StockAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)
  subjectId     Int
  subject       Subject    @relation(fields: [subjectId], references: [id])
  expectedCount Int
  actualCount   Int
  discrepancy   Int
  notes         String?

  @@unique([auditId, subjectId])
  @@index([auditId])
  @@index([subjectId])
}


model Incident {
  id               Int      @id @default(autoincrement())
  type             String   // DAMAGED, LOST, NEW, RECOVERED, DONATION
  date             DateTime
  subjectId        Int?
  subject          Subject? @relation(fields: [subjectId], references: [id])
  bookTitle        String
  condition        String?
  comment          String?
  reportedBy       String?
  responsibleParty String?
  studentClass     String?
  actionTaken      String?
  createdAt        DateTime @default(now())
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  subjectId  Int
  subject    Subject  @relation(fields: [subjectId], references: [id])
  field      String
  oldValue   String
  newValue   String
  changedBy  String?
  changedAt  DateTime @default(now())
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  role      String   @default("LIBRARIAN")
  pinHash   String?
  createdAt DateTime @default(now())
}

model Checkout {
  id               Int       @id @default(autoincrement())
  subjectId        Int
  subject          Subject   @relation(fields: [subjectId], references: [id])
  studentName      String
  studentClass     String?
  checkoutDate     DateTime  @default(now())
  dueDate          DateTime
  returnDate       DateTime?
  status           String    @default("ACTIVE") // ACTIVE, RETURNED, OVERDUE, LOST
  conditionOut     Int       // 3=Good, 2=Normal, 1=Damaged
  conditionIn      Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([subjectId])
}

model BorrowingRule {
  id                 Int      @id @default(autoincrement())
  roleOrGrade        String   @unique
  maxBooksAllowed    Int      @default(2)
  borrowDurationDays Int      @default(14)
  finePerDay         Float    @default(0.0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model AppConfig {
  id                      Int       @id @default(1)
  autoBackupEnabled       Boolean   @default(false)
  autoBackupPath          String?
  autoBackupIntervalHours Int       @default(24)
  lastAutoBackupAt        DateTime?
  lanSyncEnabled          Boolean   @default(false)
  lanPort                 Int       @default(8085)
  lanPasscode             String?   @default("quantlib-sync")
  lastLanSyncAt           DateTime?
  updatedAt               DateTime  @updatedAt
}


